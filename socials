<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cee Cuatro | Socials</title>
    <style>
        :root {
            --green: #1DB954;
            --black: #050505;
            --card: #121212;
        }

        body {
            margin: 0;
            background: var(--black);
            color: white;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 60px 20px;
        }

        .profile-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .pfp {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 3px solid var(--green);
            margin-bottom: 15px;
            object-fit: cover;
        }

        h1 { font-size: 1.8rem; letter-spacing: 2px; margin: 0; }
        p { color: #b3b3b3; font-size: 0.9rem; }

        .links-container {
            width: 100%;
            max-width: 500px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .social-link {
            background: var(--card);
            border: 1px solid #282828;
            padding: 18px;
            border-radius: 12px;
            text-decoration: none;
            color: white;
            font-weight: 600;
            text-align: center;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .social-link:hover {
            background: #1f1f1f;
            border-color: var(--green);
            transform: scale(1.02);
        }

        .social-link svg {
            width: 20px;
            fill: white;
        }

        footer {
            margin-top: 60px;
            font-size: 0.7rem;
            color: #444;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <div class="profile-header">
        <img src="top2.webp" class="pfp" alt="Cee Cuatro">
        <h1>CEE CUATRO</h1>
        <p>Official Links</p>
    </div>

    <div class="links-container">
        <a href="https://open.spotify.com/artist/1pjb5aGYKrEPxSMK4txdhk" class="social-link" target="_blank">
            Spotify
        </a>
        <a href="https://www.tiktok.com/@ceecuatrotv" class="social-link" target="_blank">
            TikTok
        </a>
        <a href="https://www.instagram.com/ceecuatrognt" class="social-link" target="_blank">
            Instagram
        </a>
        <a href="https://www.youtube.com/@ceecuatrotv" class="social-link" target="_blank">
            YouTube
        </a>
    </div>

    <footer>CEE CUATRO &copy; 2026</footer>

</body>
</html>
